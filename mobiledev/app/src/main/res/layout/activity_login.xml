<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F3FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🫧"
            android:textSize="48sp"
            android:layout_marginTop="64dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LabaLink"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#9333EA"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Laundry Management System"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"/>

        <!-- Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sign in to your account"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Error message -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#DC2626"
                    android:textSize="13sp"
                    android:background="#FEE2E2"
                    android:padding="12dp"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <!-- Email -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter your email"
                    android:background="@drawable/input_background"
                    android:padding="14dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="16dp"/>

                <!-- Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter your password"
                    android:background="@drawable/input_background"
                    android:padding="14dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="24dp"/>

                <!-- Login Button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Login"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:backgroundTint="#9333EA"
                    android:layout_marginBottom="16dp"/>

                <!-- Register link -->
                <TextView
                    android:id="@+id/tvRegisterLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? Register here"
                    android:textSize="13sp"
                    android:textColor="#9333EA"
                    android:gravity="center"
                    android:padding="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 LabaLink. All rights reserved."
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>