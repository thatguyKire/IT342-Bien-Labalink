<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Machine Icon Box -->
        <TextView
            android:id="@+id/tvMachineIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🫧"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/icon_bg_purple"
            android:layout_marginBottom="10dp"/>

        <!-- Machine Type -->
        <TextView
            android:id="@+id/tvMachineType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WASHER"
            android:textSize="10sp"
            android:textColor="#9CA3AF"
            android:letterSpacing="0.05"/>

        <!-- Machine Name -->
        <TextView
            android:id="@+id/tvMachineName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Washer 01"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="8dp"/>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvMachineStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/badge_pending"
            android:layout_marginBottom="8dp"/>

        <!-- Hourly Rate -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱"
                android:textSize="11sp"
                android:layout_marginEnd="3dp"/>

            <TextView
                android:id="@+id/tvHourlyRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱25.00/hr"
                android:textSize="12sp"
                android:textColor="#6B7280"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>